{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "IBKR Options Workstation",
  "version": "0.1.0",
  "identifier": "llc.vanaken.ibkr-options-workstation",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd .. && ./scripts/dev_dashboard.sh",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "IBKR Options Workstation",
        "width": 1600,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 860,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
