# Dashboard mode: use `mock` for offline UI work or `ibkr` for a live IB Gateway session.
OPTIONS_DASHBOARD_DATA_MODE=mock

# Execution mode:
# - `paper` enables explicit paper-account option previews and paper order submission.
# - `disabled` keeps the dashboard read-only.
OPTIONS_DASHBOARD_EXECUTION_MODE=paper

# IB Gateway / TWS socket API settings.
# IB Gateway paper default is typically 4002. TWS paper is typically 7497.
OPTIONS_DASHBOARD_IB_HOST=127.0.0.1
OPTIONS_DASHBOARD_IB_PORT=4002
OPTIONS_DASHBOARD_IB_CLIENT_ID=17
OPTIONS_DASHBOARD_IB_ACCOUNT_ID=

# 1=live, 2=frozen, 3=delayed, 4=delayed frozen
OPTIONS_DASHBOARD_IB_MARKET_DATA_TYPE=1
OPTIONS_DASHBOARD_IB_CONNECT_TIMEOUT_SECONDS=8
OPTIONS_DASHBOARD_IB_REQUEST_TIMEOUT_SECONDS=12
OPTIONS_DASHBOARD_IB_ORDER_ACK_TIMEOUT_SECONDS=4
OPTIONS_DASHBOARD_IB_RECONNECT_INTERVAL_SECONDS=5
OPTIONS_DASHBOARD_IB_UNDERLYING_EXCHANGE=SMART
OPTIONS_DASHBOARD_IB_OPTION_EXCHANGE=SMART
OPTIONS_DASHBOARD_IB_CURRENCY=USD

# Chain and analytics tuning.
OPTIONS_DASHBOARD_CHAIN_EXPIRY_LIMIT=6
OPTIONS_DASHBOARD_CHAIN_STRIKE_LIMIT=14
OPTIONS_DASHBOARD_CHAIN_MONEYNESS_PCT=0.18
OPTIONS_DASHBOARD_CHAIN_BATCH_SIZE=40
OPTIONS_DASHBOARD_CHAIN_CACHE_TTL_SECONDS=12
OPTIONS_DASHBOARD_SNAPSHOT_CACHE_TTL_SECONDS=10
OPTIONS_DASHBOARD_SAFETY_BUFFER=25000
OPTIONS_DASHBOARD_WATCHLIST=NVDA,IREN,AXTI,PYPL,GLD,IAU,VOO

# Local dev ports.
OPTIONS_DASHBOARD_BACKEND_HOST=127.0.0.1
OPTIONS_DASHBOARD_BACKEND_PORT=8000
OPTIONS_DASHBOARD_FRONTEND_PORT=5173
