# Platform mode: use `mock` for offline UI work or `ibkr` for a live IB Gateway session.
INVESTING_PLATFORM_DATA_MODE=mock

# Execution mode:
# - `paper` enables explicit paper-account option previews and paper order submission.
# - `disabled` keeps the dashboard read-only.
INVESTING_PLATFORM_EXECUTION_MODE=paper

# IB Gateway / TWS socket API settings.
# IB Gateway paper default is typically 4002. TWS paper is typically 7497.
INVESTING_PLATFORM_IB_HOST=127.0.0.1
INVESTING_PLATFORM_IB_PORT=4002
INVESTING_PLATFORM_IB_CLIENT_ID=17
INVESTING_PLATFORM_IB_ACCOUNT_ID=

# 1=live, 2=frozen, 3=delayed, 4=delayed frozen
INVESTING_PLATFORM_IB_MARKET_DATA_TYPE=1
INVESTING_PLATFORM_IB_CONNECT_TIMEOUT_SECONDS=8
INVESTING_PLATFORM_IB_REQUEST_TIMEOUT_SECONDS=12
INVESTING_PLATFORM_IB_ORDER_ACK_TIMEOUT_SECONDS=4
INVESTING_PLATFORM_IB_RECONNECT_INTERVAL_SECONDS=5
INVESTING_PLATFORM_IB_UNDERLYING_EXCHANGE=SMART
INVESTING_PLATFORM_IB_OPTION_EXCHANGE=SMART
INVESTING_PLATFORM_IB_CURRENCY=USD

# Chain and analytics tuning.
INVESTING_PLATFORM_CHAIN_EXPIRY_LIMIT=6
INVESTING_PLATFORM_CHAIN_STRIKE_LIMIT=30
INVESTING_PLATFORM_CHAIN_MONEYNESS_PCT=0.18
INVESTING_PLATFORM_CHAIN_BATCH_SIZE=40
INVESTING_PLATFORM_CHAIN_HISTORICAL_FALLBACK_CONTRACT_LIMIT=4
INVESTING_PLATFORM_CHAIN_CACHE_TTL_SECONDS=120
INVESTING_PLATFORM_SNAPSHOT_CACHE_TTL_SECONDS=10
INVESTING_PLATFORM_SAFETY_BUFFER=25000
INVESTING_PLATFORM_WATCHLIST=NVDA,IREN,AXTI,PYPL,GLD,IAU,VOO

# Research library and SEC EDGAR downloader settings.
INVESTING_PLATFORM_RESEARCH_ROOT=~/Documents/Finances/research
INVESTING_PLATFORM_EDGAR_USER_AGENT=Your Name your_email@example.com
INVESTING_PLATFORM_EDGAR_MAX_REQUESTS_PER_SECOND=5
INVESTING_PLATFORM_EDGAR_TIMEOUT_SECONDS=30
INVESTING_PLATFORM_EDGAR_RETRY_LIMIT=5

# Coinbase connector settings.
# For a CDP Secret API Key with Ed25519, set COINBASE_API_KEY_ID + COINBASE_API_KEY.
# For PEM-style key material, set COINBASE_API_KEY_NAME + COINBASE_API_PRIVATE_KEY.
# COINBASE_API_KEY can also hold a bearer token if you already have one.
COINBASE_API_KEY=
COINBASE_API_KEY_ID=
COINBASE_API_KEY_NAME=
COINBASE_API_PRIVATE_KEY=
COINBASE_API_KEY_FILE=
COINBASE_API_BASE_URL=https://api.coinbase.com
COINBASE_TIMEOUT_SECONDS=15
COINBASE_SNAPSHOT_CACHE_TTL_SECONDS=30

# Local dev ports.
INVESTING_PLATFORM_BACKEND_HOST=127.0.0.1
INVESTING_PLATFORM_BACKEND_PORT=8000
INVESTING_PLATFORM_FRONTEND_PORT=5173

# Local runtime state. Keep this outside the repo for public-safe defaults.
INVESTING_PLATFORM_FILESYSTEM_CONNECTORS_STATE_PATH=~/.investing-platform/filesystem-connectors/connectors.json
